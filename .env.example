APP_ENV=development
API_KEY=replace-with-local-api-key
REQUIRE_API_KEY=true
USE_MOCK_AI=true
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_STORY_MODEL=gpt-4.1
AWS_REGION=us-east-1
S3_BUCKET=
S3_PREFIX=storybook
SES_SENDER_EMAIL=
SES_ADMIN_EMAIL=
EMAIL_DELIVERY_ENABLED=false
MAX_IMAGES_PER_JOB=40
MAX_IMAGE_BYTES=10000000
IMAGE_MAX_WIDTH=1600
IMAGE_MAX_HEIGHT=1600
JPG_QUALITY=82
JOB_STORE_PATH=data/jobs.sqlite3
WORK_DIR=data/work
LOCAL_OUTBOX_DIR=data/outbox
PDF_PAGE_SIZE=8.5in 8.5in
PDF_MARGIN=0.5in
PDF_BASE_URL=http://localhost:8000
